{
	"name": "hello-plugin",
	"version": "1.0.0",
	"description": "A simple Hello World plugin for Obsidian",
	"main": "main.js",
	"type": "module",
	"scripts": {
		"dev": "node esbuild.config.mjs",
		"build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
		"setup": "mkdir -p ../vault/.obsidian/plugins && ln -sfn ../../../plugins ../vault/.obsidian/plugins/hello-plugin"
	},
	"devDependencies": {
		"@types/node": "^22.15.17",
		"esbuild": "0.25.5",
		"obsidian": "latest",
		"typescript": "^5.8.3"
	}
}